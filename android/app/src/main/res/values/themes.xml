<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. The Compose theme handles colors at runtime. -->
    <style name="Theme.BigCityPlumbing" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/brand_blue</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Launch splash: brand-blue background with the centered logo. -->
    <style name="Theme.BigCityPlumbing.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.BigCityPlumbing</item>
    </style>
</resources>
